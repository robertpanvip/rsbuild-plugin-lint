{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2023",
    "types": ["node"],
    "lib": ["DOM", "ESNext"],
    "declaration": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "module": "node20",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
  },
  "include": ["src"]
}
